# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly set line endings for text files
*.cls text eol=lf
*.xml text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml texto eol=lf
*.ts texto eol=lf
*.tsx text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.zip binary
*.wsdl binary